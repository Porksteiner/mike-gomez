---
/**
 * Home page — composed from src/data/pages/home.json via the block registry.
 * Edit blocks visually in /studio, or directly in home.json.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import RenderBlocks from "../components/RenderBlocks.astro";
import page from "../data/pages/home.json";
---

<BaseLayout title={page.title}>
  <main>
    <RenderBlocks blocks={page.blocks} />
  </main>
</BaseLayout>
