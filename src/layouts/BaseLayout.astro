---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Mike Gomez — Freelance web & mobile developer",
  description = "Mike Gomez is a freelance developer building websites and mobile apps for founders and small businesses. Honest work, built with care, shipped on time.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#d4af6d" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Cinzel:wght@400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body class="bg-void text-bone font-sans grain">
    <div id="scroll-progress" class="scroll-progress"></div>
    <div id="cursor-dot" class="cursor-dot hidden md:block"></div>
    <div id="cursor-ring" class="cursor-ring hidden md:block"></div>

    <slot />

    <script src="/scripts/site.js" is:inline></script>
    <script is:inline>
      // Studio injection — only loads when the URL carries ?studio=1
      if (typeof window !== "undefined" && location.search.includes("studio=1")) {
        const s = document.createElement("script");
        s.src = "/studio/inject.js";
        s.async = true;
        document.head.appendChild(s);
      }
    </script>
  </body>
</html>
