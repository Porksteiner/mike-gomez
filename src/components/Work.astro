---
// Two projects, both shown well. No "your project here" begging card.
---

<section id="work" class="relative py-32 sm:py-44 border-t border-iron bg-void">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14">
    {/* Header */}
    <div class="grid grid-cols-12 gap-6 mb-16 sm:mb-20">
      <div class="col-span-12 md:col-span-3 reveal">
        <p class="text-[11px] uppercase tracking-[0.22em] font-mono text-gold">
          <span class="inline-block w-6 h-px bg-gold align-middle mr-2"></span>
          Selected work
        </p>
      </div>
      <div class="col-span-12 md:col-span-9 reveal reveal-delay-1">
        <div class="flex flex-wrap items-end justify-between gap-6">
          <h2
            class="font-display uppercase leading-[0.9] text-[clamp(40px,7vw,96px)] tracking-[-0.01em]"
          >
            <span class="block">Recent work.</span>
            <span class="block text-stroke">Real, shipped, paid.</span>
          </h2>
          <a
            href="#contact"
            class="text-[12px] uppercase tracking-[0.2em] font-mono text-smoke hover:text-bone link-flare transition"
          >
            Work with me &rarr;
          </a>
        </div>
      </div>
    </div>

    {/* Grid */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 sm:gap-6 auto-rows-[minmax(280px,auto)]">
      {/* ===== BaitIQ — featured ===== */}
      <article
        class="reveal lg:col-span-12 group relative overflow-hidden border border-iron hover:border-gold/60 transition bg-coal"
      >
        <div class="absolute inset-0 bg-gradient-to-br from-coal via-honey/25 to-graphite"></div>
        <div
          class="absolute inset-0 opacity-[0.5]"
          style="background-image: linear-gradient(to right, rgba(168,133,74,0.15) 1px, transparent 1px), linear-gradient(to bottom, rgba(168,133,74,0.15) 1px, transparent 1px); background-size: 40px 40px;"
        ></div>

        <div class="relative flex flex-col gap-8 sm:gap-10 p-6 sm:p-10">
          {/* Top meta row */}
          <div class="flex items-start justify-between gap-4">
            <span class="font-mono text-[11px] tracking-[0.22em] text-bone/70 uppercase">
              01 — 2026
            </span>
            <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-bone/70 text-right">
              iOS · React Native · OpenAI
            </span>
          </div>

          {/* Main split: text on left, laptop mockup on right */}
          <div class="grid grid-cols-1 md:grid-cols-12 gap-8 sm:gap-12 items-center">
            <div class="md:col-span-5 flex flex-col gap-5 order-2 md:order-1">
              {/* Small icon badge */}
              <div class="relative w-fit">
                <div class="absolute inset-0 -m-3 bg-gold/15 blur-2xl rounded-full"></div>
                <img
                  src="/projects/baitiq-icon.png"
                  alt="BaitIQ app icon"
                  width="120"
                  height="120"
                  loading="lazy"
                  class="relative w-16 sm:w-20 h-auto rounded-[24%] shadow-[0_15px_30px_-10px_rgba(0,0,0,0.4)] ring-1 ring-iron"
                />
              </div>

              <h3
                class="font-display uppercase text-[clamp(48px,6.5vw,96px)] leading-[0.95] tracking-[-0.02em] group-hover:text-gold transition-colors"
              >
                BaitIQ
              </h3>

              <p class="text-paper text-lg leading-snug max-w-md">
                AI fishing intelligence — point your camera, get bait
                recommendations tuned for your weather, location, and
                conditions. <span class="text-bone">Live on the iOS App Store.</span>
              </p>

              {/* Metric pills */}
              <div class="flex flex-wrap items-center gap-3 mt-2">
                <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-void/80 border border-iron rounded-full text-[11px] uppercase tracking-[0.2em] font-mono text-bone/90">
                  <span class="relative flex w-1.5 h-1.5">
                    <span class="absolute inline-flex w-full h-full rounded-full bg-gold opacity-75 animate-ping"></span>
                    <span class="relative inline-flex w-1.5 h-1.5 rounded-full bg-gold"></span>
                  </span>
                  Live on the App Store
                </span>
                <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-void/80 border border-iron rounded-full text-[11px] uppercase tracking-[0.2em] font-mono text-bone/90">
                  <span class="text-gold tracking-normal text-[13px] leading-none">★★★★★</span>
                  <span>App Store</span>
                </span>
                <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-void/80 border border-iron rounded-full text-[11px] uppercase tracking-[0.2em] font-mono text-smoke">
                  v2 shipping this week
                </span>
              </div>
            </div>

            {/* Right column: laptop mockup */}
            <div class="md:col-span-7 order-1 md:order-2">
              <div class="relative">
                {/* Soft glow behind the laptop */}
                <div class="absolute inset-0 -m-6 bg-gold/15 blur-3xl rounded-full"></div>
                <img
                  src="/projects/baitiq-marketing.png"
                  alt="BaitIQ marketing site shown on a laptop — “Throw the right bait. Every time.”"
                  width="1200"
                  height="800"
                  loading="lazy"
                  class="relative w-full h-auto transition-transform duration-700 group-hover:scale-[1.02]"
                />
              </div>
            </div>
          </div>
        </div>
      </article>

      {/* ===== Unlearn Your Credit Habits — full width ===== */}
      <article
        class="reveal reveal-delay-1 lg:col-span-12 group relative overflow-hidden border border-iron hover:border-gold/60 transition bg-coal"
      >
        <div class="absolute inset-0 bg-gradient-to-tr from-coal via-graphite to-honey/40"></div>
        <div
          class="absolute inset-0 opacity-50"
          style="background-image: radial-gradient(rgba(45,31,10,0.18) 1px, transparent 1px); background-size: 8px 8px;"
        ></div>
        <span class="absolute -bottom-6 -right-4 font-display text-[clamp(120px,16vw,260px)] uppercase leading-none text-bone/10 select-none">
          ULY
        </span>

        <div class="relative grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-10 p-6 sm:p-10 min-h-[300px] items-center">
          <div class="md:col-span-8 flex flex-col gap-5">
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-[11px] tracking-[0.22em] text-bone/70 uppercase">
                02 — 2026
              </span>
              <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-bone/70 text-right">
                Brand · Site · Strategy
              </span>
            </div>

            <h3
              class="font-display uppercase text-[clamp(40px,6vw,84px)] leading-[0.95] tracking-[-0.02em] group-hover:text-gold transition-colors"
            >
              Unlearn Your Credit Habits
            </h3>

            <p class="text-paper text-lg leading-snug max-w-2xl">
              Brand identity and conversion-focused landing site for a credit
              education business. Custom-designed in Astro, with payment +
              booking integrations. From sketch to staged in twelve weeks.
            </p>

            {/* Metric pills */}
            <div class="flex flex-wrap items-center gap-3 mt-2">
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-void/80 border border-iron rounded-full text-[11px] uppercase tracking-[0.2em] font-mono text-bone/90">
                Launching Q3 2026
              </span>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-void/80 border border-iron rounded-full text-[11px] uppercase tracking-[0.2em] font-mono text-bone/90">
                12 weeks · solo
              </span>
              <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-void/80 border border-iron rounded-full text-[11px] uppercase tracking-[0.2em] font-mono text-smoke">
                Astro · Tailwind · Stripe
              </span>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>
