---
import faqData from "../data/faq.json";
const faqs = faqData.items;
---

<section id="faq" class="relative py-32 sm:py-44 bg-void">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14">
    {/* Section opener */}
    <div class="mb-16 sm:mb-20 max-w-3xl reveal">
      <h2 class="font-display uppercase leading-[0.9] text-[clamp(40px,6.5vw,88px)] tracking-[-0.01em]">
        <span class="block">Questions you</span>
        <span class="block"><span class="text-gold">might</span> have.</span>
      </h2>
      <p class="mt-6 text-lg text-paper leading-relaxed max-w-xl">
        If yours isn&rsquo;t here,
        <a href="#contact" class="text-gold hover:text-bone link-flare transition">
          send it over
        </a>
        and I&rsquo;ll answer the same day.
      </p>
    </div>

    <div class="max-w-4xl mx-auto">
      {
        faqs.map((f, i) => (
          <details
            class={`reveal reveal-delay-${(i % 4) + 1} group border-b border-iron`}
            open={i === 0}
          >
            <summary class="flex items-start gap-6 py-6 sm:py-7 cursor-pointer list-none text-bone hover:text-gold transition">
              <span class="flex-1 font-display uppercase text-[clamp(18px,2vw,28px)] leading-snug tracking-[-0.01em] pr-4">
                {f.q}
              </span>
              <span
                class="flex-shrink-0 mt-1 w-7 h-7 flex items-center justify-center text-smoke group-open:text-gold group-hover:text-gold transition"
                aria-hidden="true"
              >
                <svg
                  class="w-4 h-4 transition-transform group-open:rotate-45"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </span>
            </summary>
            <div class="pb-7 pr-12 -mt-2 text-paper text-[16px] sm:text-[17px] leading-relaxed">
              <p>{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
