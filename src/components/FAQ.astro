---
const faqs = [
  {
    q: "Who owns the code I'm paying you to build?",
    a: "You do. Once we're squared away, all the source code, designs, and assets are 100% yours. The only thing I keep is the right to mention I worked on it (and only if that's okay with you).",
  },
  {
    q: "Will you sign an NDA?",
    a: "Happy to. Send yours over, or I can share a simple one-page mutual NDA. Either way, what we talk about stays between us.",
  },
  {
    q: "What if we go over budget or scope?",
    a: "I quote fixed prices on a fixed scope, so the number we agree on is the number you pay. If you want to add something mid-build, we'll chat about it and I'll give you a clear estimate before any extra work starts. And if I underestimated to begin with, that's on me, the original price still holds.",
  },
  {
    q: "Do you do the design too, or do I bring designs?",
    a: "Either works! I usually design and build together since it tends to be faster and more cohesive. If you've already got a designer or brand guidelines, I'll happily work with what you have.",
  },
  {
    q: "What are your payment terms?",
    a: "Usually 50% up front, 50% on launch. For longer projects we can split the back half into milestone payments, whatever works for your cash flow. Stripe handles the invoices: card, ACH, or wire.",
  },
  {
    q: "What if I'm not happy with something?",
    a: "Please tell me as soon as you can! I share work weekly so we can catch anything early, while it's still easy to change. If we get to launch and something still isn't right, fixes during the 30-day support window are on me.",
  },
  {
    q: "What if I don't know exactly what I want yet?",
    a: "That's totally fine, and pretty normal. Bring me whatever you've got, a rough idea, a sketch, a pile of screenshots. We'll figure out the shape of it together on the first call.",
  },
];
---

<section id="faq" class="relative py-32 sm:py-44 bg-void">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14">
    {/* Section opener */}
    <div class="mb-16 sm:mb-20 max-w-3xl reveal">
      <h2 class="font-display uppercase leading-[0.9] text-[clamp(40px,6.5vw,88px)] tracking-[-0.01em]">
        <span class="block">Questions you</span>
        <span class="block"><span class="text-gold">might</span> have.</span>
      </h2>
      <p class="mt-6 text-lg text-paper leading-relaxed max-w-xl">
        If yours isn&rsquo;t here,
        <a href="#contact" class="text-gold hover:text-bone link-flare transition">
          send it over
        </a>
        and I&rsquo;ll answer the same day.
      </p>
    </div>

    <div class="max-w-4xl mx-auto">
      {
        faqs.map((f, i) => (
          <details
            class={`reveal reveal-delay-${(i % 4) + 1} group border-b border-iron`}
            open={i === 0}
          >
            <summary class="flex items-start gap-6 py-6 sm:py-7 cursor-pointer list-none text-bone hover:text-gold transition">
              <span class="flex-1 font-display uppercase text-[clamp(18px,2vw,28px)] leading-snug tracking-[-0.01em] pr-4">
                {f.q}
              </span>
              <span
                class="flex-shrink-0 mt-1 w-7 h-7 flex items-center justify-center text-smoke group-open:text-gold group-hover:text-gold transition"
                aria-hidden="true"
              >
                <svg
                  class="w-4 h-4 transition-transform group-open:rotate-45"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </span>
            </summary>
            <div class="pb-7 pr-12 -mt-2 text-paper text-[16px] sm:text-[17px] leading-relaxed">
              <p>{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
