---
/*
  HOW I WORK — merged Manifesto (commitments) + Process (4 stages).
  Written as an editorial essay, not a card grid. Each stage gets a
  small kicker, a Cinzel numeral, and prose. The commitments are
  woven into the prose, italicized when they appear.
*/

const stages = [
  {
    n: "I",
    kicker: "Intake",
    duration: "Day 0",
    body:
      "Two calls. We talk about what you're building, by when, and whether I'm the right person for it. No deck, no slides. If we shouldn't work together, I'll say so up front."
  },
  {
    n: "II",
    kicker: "Brief and estimate",
    duration: "Day 1",
    body:
      "Within twenty-four hours of the call: a written scope, a timeline, a fixed price. Honest estimates, even when they're not what you'd like to hear."
  },
  {
    n: "III",
    kicker: "Build",
    duration: "Weeks 1–N",
    body:
      "Design and dev in parallel. Daily Loom updates if you want them, weekly demos if you don't. You see real working software inside a week. No surprise charges, no missed updates."
  },
  {
    n: "IV",
    kicker: "Ship and stay",
    duration: "Final + 30",
    body:
      "Launch, hand-off, and thirty days of free fixes after. Quality I'd put my name on. Because I do."
  },
];
---

<section id="how" class="relative bg-coal py-32 sm:py-44">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14">
    {/* Section opener — no mono eyebrow, no §-divider. Just a heading. */}
    <div class="mb-20 sm:mb-28 max-w-3xl">
      <h2
        class="font-display uppercase leading-[0.9] text-[clamp(48px,8vw,124px)] tracking-[-0.01em]"
      >
        <span class="block">How I</span>
        <span class="block"><span class="text-gold">actually</span> work.</span>
      </h2>
      <p class="mt-8 text-lg sm:text-xl text-paper leading-relaxed max-w-2xl">
        A practical sequence. No deck, no jargon, no surprises along the way.
        From the first call to thirty days after launch, it looks like this.
      </p>
    </div>

    {/* Pull quote in Cinzel — the operating principle */}
    <div class="my-20 sm:my-28 max-w-4xl mx-auto text-center">
      <p
        class="font-[var(--font-inscription)] tracking-[0.06em] text-[clamp(22px,2.4vw,34px)] leading-[1.35] text-ink-900"
        style="font-family: var(--font-inscription);"
      >
        Quality I&rsquo;d put my name on.
        <span class="text-gold">Because I do.</span>
      </p>
    </div>

    {/* The four stages, as editorial paragraphs */}
    <ol class="divide-y divide-iron max-w-5xl mx-auto">
      {
        stages.map((s) => (
          <li class="reveal grid grid-cols-12 gap-x-8 gap-y-3 py-12 sm:py-16">
            {/* Cinzel Roman numeral */}
            <span
              class="col-span-2 md:col-span-1 text-[clamp(28px,3vw,44px)] text-gold leading-none pt-2"
              style="font-family: var(--font-inscription); letter-spacing: 0.05em;"
            >
              {s.n}
            </span>
            <div class="col-span-10 md:col-span-3">
              <p
                class="font-mono text-[11px] uppercase tracking-[0.22em] text-smoke mb-2"
              >
                {s.duration}
              </p>
              <h3 class="font-display uppercase text-[clamp(22px,2.4vw,32px)] leading-[1.05] tracking-[-0.01em] text-bone">
                {s.kicker}
              </h3>
            </div>
            <p class="col-span-12 md:col-span-8 text-lg leading-relaxed text-paper max-w-2xl">
              {s.body}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
