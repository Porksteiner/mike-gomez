---
// Stats — desert gold accent
---

<section class="relative py-24 sm:py-32 border-t border-iron bg-void">
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-12">
      <div class="reveal">
        <span
          id="project-counter"
          class="block font-display text-[clamp(64px,9vw,144px)] leading-none text-gold tracking-[-0.02em]"
        >
          000
        </span>
        <p class="mt-3 text-[11px] uppercase tracking-[0.2em] font-mono text-smoke">
          Commits last 90 days
        </p>
      </div>
      <div class="reveal reveal-delay-1">
        <span class="block font-display text-[clamp(64px,9vw,144px)] leading-none text-bone tracking-[-0.02em]">
          1<span class="text-gold">.</span>0
        </span>
        <p class="mt-3 text-[11px] uppercase tracking-[0.2em] font-mono text-smoke">
          iOS apps on the App Store
        </p>
      </div>
      <div class="reveal reveal-delay-2">
        <span class="block font-display text-[clamp(64px,9vw,144px)] leading-none text-bone tracking-[-0.02em]">
          12<span class="text-gold">w</span>
        </span>
        <p class="mt-3 text-[11px] uppercase tracking-[0.2em] font-mono text-smoke">
          Typical brief → live
        </p>
      </div>
      <div class="reveal reveal-delay-3">
        <span class="block font-display text-[clamp(64px,9vw,144px)] leading-none text-bone tracking-[-0.02em]">
          2
        </span>
        <p class="mt-3 text-[11px] uppercase tracking-[0.2em] font-mono text-smoke">
          Open client slots
        </p>
      </div>
    </div>
  </div>
</section>
