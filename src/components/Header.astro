---
// Refined personal header — gold MG monogram + Mike Gomez wordmark
---

<header
  class="fixed top-0 inset-x-0 z-40 bg-void/70 backdrop-blur-md border-b border-iron"
>
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14 h-16 flex items-center justify-between">
    {/* Brand */}
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Mike Gomez — home">
      <svg viewBox="0 0 32 32" class="w-7 h-7" aria-hidden="true">
        <rect width="32" height="32" fill="#050403" stroke="#d4af6d" stroke-width="1.5" />
        <text
          x="16" y="23" text-anchor="middle"
          font-family="Anton, Impact, sans-serif"
          font-size="18" font-weight="700"
          fill="#d4af6d" letter-spacing="-0.5"
        >MG</text>
      </svg>
      <span class="font-display text-xl tracking-[0.14em] uppercase leading-none">
        Mike Gomez
      </span>
    </a>

    {/* Nav */}
    <nav class="hidden md:flex items-center gap-8 text-[12px] uppercase tracking-[0.18em] font-mono text-smoke">
      <a href="#work" class="link-flare hover:text-bone transition">Work</a>
      <a href="#process" class="link-flare hover:text-bone transition">Process</a>
      <a href="#now" class="link-flare hover:text-bone transition">Now</a>
      <a href="#faq" class="link-flare hover:text-bone transition">FAQ</a>
    </nav>

    {/* Status + CTA */}
    <div class="flex items-center gap-4">
      <div class="hidden sm:flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] font-mono text-smoke">
        <span class="relative flex w-2 h-2">
          <span class="absolute inline-flex w-full h-full rounded-full bg-gold opacity-75 animate-ping"></span>
          <span class="relative inline-flex w-2 h-2 rounded-full bg-gold"></span>
        </span>
        <span>Available &mdash; 2 slots</span>
        <span class="text-iron">/</span>
        <span id="live-time">— PT</span>
      </div>
      <a
        href="https://calendly.com/mike-mikegomez/30min"
        target="_blank"
        rel="noopener noreferrer"
        data-magnetic
        class="inline-flex items-center gap-2 px-4 py-2 bg-bone text-void font-mono text-[11px] uppercase tracking-[0.2em] font-semibold hover:bg-gold hover:text-void transition-colors will-change-transform"
      >
        Book a call
      </a>
    </div>
  </div>
</header>
