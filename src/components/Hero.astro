---
/*
  HERO — content-driven. All copy lives in src/data/hero.json.
  Per-line styling (stroke, gold accent, etc.) stays in the component
  because it's tightly art-directed — the data layer just controls
  the words.
*/
import hero from "../data/hero.json";
const {
  line1, line2, line3Accent, line3Rest, line4,
  bio, currentlyBuildingLabel, currentlyBuildingLines, scrollCtaLabel,
} = hero;
---

<section
  class="relative min-h-screen flex flex-col justify-end overflow-hidden pt-40 pb-12 sm:pb-16"
>
  {/* Decorative corner brackets */}
  <span class="corner-mark tl"></span>
  <span class="corner-mark tr"></span>
  <span class="corner-mark bl"></span>
  <span class="corner-mark br"></span>

  {/* Ambient mark — slowly rotating ring */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-32 -right-24 sm:-right-20 w-[600px] h-[600px] sm:w-[860px] sm:h-[860px] opacity-[0.18]"
  >
    <svg viewBox="0 0 200 200" class="w-full h-full slow-spin text-gold">
      <circle cx="100" cy="100" r="80" fill="none" stroke="currentColor" stroke-width="4" />
      <circle cx="100" cy="100" r="60" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="2 6" />
      <circle cx="100" cy="100" r="28" fill="currentColor" />
    </svg>
  </div>

  {/* Headline — per-line styling preserved; text from JSON. */}
  <h1
    data-split
    class="relative max-w-[1600px] w-full mx-auto px-6 sm:px-10 lg:px-14 font-display uppercase tracking-[-0.02em] leading-[0.88] text-[clamp(64px,12vw,212px)]"
  >
    <span class="block reveal">{line1}</span>
    <span class="block reveal reveal-delay-1">
      <span class="text-stroke">{line2}</span>
    </span>
    <span class="block reveal reveal-delay-2">
      <span class="italic font-sans font-light normal-case tracking-[-0.03em] text-gold">{line3Accent}</span>
      <span class="text-bone">{line3Rest}</span>
    </span>
    <span class="block reveal reveal-delay-3 -mt-1 sm:-mt-3">
      <span class="text-stroke-gold">{line4}</span>
    </span>
  </h1>

  {/* Bottom row */}
  <div
    class="relative max-w-[1600px] w-full mx-auto px-6 sm:px-10 lg:px-14 mt-16 sm:mt-24 grid grid-cols-12 gap-6"
  >
    <div class="col-span-12 md:col-span-6 reveal reveal-delay-3">
      <p class="text-lg sm:text-xl text-paper max-w-md leading-snug">
        {bio}
      </p>
    </div>

    <div class="col-span-12 md:col-span-3 md:col-start-8 reveal reveal-delay-4">
      <p class="text-[11px] uppercase tracking-[0.2em] font-mono text-smoke mb-2">
        {currentlyBuildingLabel}
      </p>
      <p class="text-paper text-[15px] leading-snug">
        {currentlyBuildingLines.map((line, i) => (
          <>
            {line}
            {i < currentlyBuildingLines.length - 1 && <br />}
          </>
        ))}
      </p>
    </div>

    <div class="col-span-12 md:col-span-2 md:col-start-11 flex items-end justify-end reveal reveal-delay-4">
      <a
        href="#work"
        class="flex flex-col items-end gap-2 text-[11px] uppercase tracking-[0.2em] font-mono text-smoke hover:text-bone transition"
      >
        {scrollCtaLabel}
        <svg viewBox="0 0 24 24" class="w-4 h-6" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 4 V20 M5 13 L12 20 L19 13" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
