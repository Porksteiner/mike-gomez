---
interface Props {
  data?: {
    heading?: string;
    logos?: { label: string; href?: string }[];
  };
  blockId?: string;
}
const { data = {}, blockId } = Astro.props;
const heading = data.heading ?? "Trusted by";
const logos = data.logos ?? [];
---

<section
  class="logo-cloud-block relative py-20 sm:py-24 bg-void border-y border-iron"
  data-block-id={blockId}
  data-block-type="logo-cloud"
>
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14">
    <p
      class="text-center font-mono text-[11px] uppercase tracking-[0.25em] text-smoke mb-10"
      data-edit="heading"
    >
      {heading}
    </p>
    <ul class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6 sm:gap-x-16">
      {logos.map((l, i) => (
        <li>
          {l.href ? (
            <a
              href={l.href}
              class="font-display uppercase text-[clamp(20px,3vw,32px)] tracking-[-0.01em] text-paper opacity-70 hover:opacity-100 hover:text-gold transition"
              target="_blank"
              rel="noopener"
              data-edit={`logos[${i}].label`}
              data-edit-attr={`logos[${i}].href:href`}
            >
              {l.label}
            </a>
          ) : (
            <span
              class="font-display uppercase text-[clamp(20px,3vw,32px)] tracking-[-0.01em] text-paper opacity-70"
              data-edit={`logos[${i}].label`}
            >
              {l.label}
            </span>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>
