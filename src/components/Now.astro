---
import nowData from "../data/now.json";
const currentlyBuilding = nowData.items;
---

<section
  id="now"
  class="relative py-32 sm:py-44 border-t border-iron bg-void"
>
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14">
    <div class="grid grid-cols-12 gap-6 mb-20">
      <div class="col-span-12 md:col-span-3 reveal">
        <p class="text-[11px] uppercase tracking-[0.22em] font-mono text-gold">
          <span class="inline-block w-6 h-px bg-gold align-middle mr-2"></span>
          Now
        </p>
      </div>
      <div class="col-span-12 md:col-span-9 reveal reveal-delay-1">
        <div class="flex flex-wrap items-end justify-between gap-6">
          <h2
            class="font-display uppercase leading-[0.9] text-[clamp(40px,7vw,96px)] tracking-[-0.01em]"
          >
            <span class="block">What I'm</span>
            <span class="block">building <span class="text-gold">right now.</span></span>
          </h2>
          <p class="text-[11px] uppercase tracking-[0.22em] font-mono text-smoke">
            <span class="text-gold">●</span> Updated this week
          </p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-6">
      {
        currentlyBuilding.map((item, i) => (
          <article
            class={`reveal reveal-delay-${(i % 4) + 1} col-span-12 md:col-span-4 border border-iron p-7 sm:p-8 flex flex-col gap-5 bg-coal hover:bg-coal/60 hover:border-gold/60 transition`}
          >
            <div class="flex items-start justify-between gap-4">
              <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-gold">
                {item.status}
              </span>
              <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-smoke">
                0{i + 1}
              </span>
            </div>
            <h3 class="font-display uppercase text-[clamp(28px,3.2vw,40px)] leading-[1] tracking-[-0.01em]">
              {item.name}
            </h3>
            <p class="font-mono text-[12px] uppercase tracking-[0.18em] text-paper">
              {item.detail}
            </p>
            <p class="text-paper text-[15px] leading-relaxed mt-auto pt-4 border-t border-iron italic font-sans font-light">
              {item.update}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
