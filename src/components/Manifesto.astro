---
// Commitments — service-oriented promises, not provocations.
const commitments = [
  { n: "01", text: "Honest estimates. Even when they're not what you'd like to hear." },
  { n: "02", text: "Clear communication. No surprise charges, no missed updates." },
  { n: "03", text: "Quality I'd put my name on. Because I do." },
  { n: "04", text: "Thirty days of free support after every launch." },
  { n: "05", text: "If we shouldn't work together, I'll say so up front." },
];
---

<section
  id="manifesto"
  class="relative py-32 sm:py-44 border-t border-iron bg-void"
>
  <div class="max-w-[1600px] mx-auto px-6 sm:px-10 lg:px-14">
    <div class="grid grid-cols-12 gap-6 mb-20 sm:mb-28">
      <div class="col-span-12 md:col-span-3 reveal">
        <p class="text-[11px] uppercase tracking-[0.22em] font-mono text-gold mb-3">
          <span class="inline-block w-6 h-px bg-gold align-middle mr-2"></span>
          Commitments
        </p>
      </div>
      <div class="col-span-12 md:col-span-9 reveal reveal-delay-1">
        <h2
          class="font-display uppercase leading-[0.9] text-[clamp(40px,7vw,108px)] tracking-[-0.01em]"
        >
          <span class="block">What you can</span>
          <span class="block"><span class="text-gold">expect</span> from me.</span>
        </h2>
      </div>
    </div>

    <ol class="divide-y divide-iron">
      {
        commitments.map((b, i) => (
          <li
            class={`reveal reveal-delay-${(i % 4) + 1} grid grid-cols-12 gap-6 py-7 sm:py-9 group hover:bg-coal/40 transition`}
          >
            <span class="col-span-2 md:col-span-1 font-mono text-smoke text-sm pt-2">
              {b.n}
            </span>
            <span class="col-span-10 md:col-span-9 font-display uppercase text-[clamp(28px,5vw,68px)] leading-[0.98] tracking-[-0.01em]">
              {b.text}
            </span>
            <span class="hidden md:flex col-span-2 items-center justify-end text-gold opacity-0 group-hover:opacity-100 transition">
              <svg viewBox="0 0 24 24" class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 12 H19 M13 6 L19 12 L13 18" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </li>
        ))
      }
    </ol>

    <div class="mt-20 grid grid-cols-12 gap-6 reveal">
      <p
        class="col-span-12 md:col-span-6 md:col-start-4 text-paper text-lg leading-relaxed"
      >
        I&rsquo;ve shipped iOS apps to the App Store, websites for family
        businesses, desktop tools, and game prototypes. Different stacks, same
        operating mode: scope tight, build well, ship on the date we agreed
        on.
      </p>
    </div>
  </div>
</section>
