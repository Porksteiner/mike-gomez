      "fields": [
        { "name": "heading", "label": "Heading", "type": "text" },
        {
          "name": "images",
          "label": "Images",
          "type": "list",
          "itemFields": [
            { "name": "src", "label": "Image", "type": "image" },
            { "name": "alt", "label": "Alt text", "type": "text" }
