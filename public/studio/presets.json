      "fields": [
        { "name": "eyebrow", "label": "Eyebrow", "type": "text" },
        { "name": "heading", "label": "Heading", "type": "textarea" },
        { "name": "body", "label": "Body", "type": "textarea" },
        { "name": "image", "label": "Image path", "type": "image" },
        {
          "name": "side",
          "label": "Image side",
          "type": "select",
          "options": ["left", "right"]
        }
      ]
