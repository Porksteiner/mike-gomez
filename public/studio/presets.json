      "fields": [
        { "name": "eyebrow", "label": "Eyebrow", "type": "text" },
        { "name": "headline", "label": "Headline", "type": "textarea" },
        { "name": "sub", "label": "Subhead", "type": "textarea" },
        { "name": "ctaLabel", "label": "CTA label", "type": "text" },
